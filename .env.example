GEMINI_API_KEY=YOUR_KEY_HERE
OPENAI_API_KEY=YOUR_KEY_HERE
QWEN_API_KEY=sk-mnmarlfiwaknguxvanyhmhuzksfuoqofttkfunbkztzkwgzb

# LLM Provider: gemini, openai, claude, qwen
LLM_PROVIDER=qwen

# Claude
ANTHROPIC_API_KEY=your_claude_key_here

# Qwen (SiliconFlow)
QWEN_API_KEY=your_siliconflow_key_here
QWEN_BASE_URL=https://api.siliconflow.cn/v1
QWEN_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Model OpenAI sẽ dùng (mặc định: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# GenProg APR settings
# Đường dẫn tuyệt đối tới binary GenProg (e.g. /home/user/genprog-source-v3.0/src/repair)
GENPROG_BIN=repair
# Timeout tổng (giây) cho mỗi lần chạy GenProg trên một bug
GENPROG_TIMEOUT=3600
# Timeout (giây) cho mỗi test case khi validate bản vá
GENPROG_TEST_TIMEOUT=50
