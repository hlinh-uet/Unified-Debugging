GEMINI_API_KEY=YOUR_KEY_HERE
OPENAI_API_KEY=YOUR_KEY_HERE

# LLM Provider cho APR LLM-based: "gemini" (mặc định) hoặc "openai"
LLM_PROVIDER=gemini

# Model OpenAI sẽ dùng (mặc định: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# GenProg APR settings
# Đường dẫn tuyệt đối tới binary GenProg (e.g. /home/user/genprog-source-v3.0/src/repair)
GENPROG_BIN=repair
# Timeout tổng (giây) cho mỗi lần chạy GenProg trên một bug
GENPROG_TIMEOUT=3600
# Timeout (giây) cho mỗi test case khi validate bản vá
GENPROG_TEST_TIMEOUT=50
