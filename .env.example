GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# LLM Provider: gemini, openai, claude, qwen, openrouter
LLM_PROVIDER=qwen

# OpenRouter / Qwen
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=UET_APR_Research
QWEN_MODEL=qwen/qwen3-coder-30b-a3b-instruct

# Claude
ANTHROPIC_API_KEY=your_claude_key_here
ANTHROPIC_BASE_URL=https://claude.zunef.com/v1/ai
ANTHROPIC_MODEL=anthropic/claude-sonnet-4.6

# OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# GenProg APR settings
GENPROG_BIN=repair
GENPROG_TIMEOUT=3600
GENPROG_TEST_TIMEOUT=50
